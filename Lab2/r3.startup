ifconfig eth0 192.168.3.1/24
ifconfig eth1 100.0.0.10/30

ip route add 192.168.1.0/24 via 100.0.0.9
ip route add 192.168.2.0/24 via 100.0.0.9
ip route add default via 100.0.0.9

dnsmasq -C /shared/dnsmasq-r3.conf

tcpdump -i eth0 -n -U -w /shared/captures/r3-dhcp.pcap 'port 67 or port 68' >/dev/null 2>&1 &